# Railway production backend env template
# Last Updated: 2026-03-23

TALMUDPEDIA_ENV_PROFILE=production
DB_TARGET=default

# Railway managed services
DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL_LOCAL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# Security and platform URLs
SECRET_KEY=replace-with-long-random-secret
PLATFORM_BASE_URL=https://platform.example.com
API_BASE_URL=https://api.example.com
CORS_ORIGINS=https://platform.example.com

# Disable local/dev bootstrap behavior
BACKEND_AUTO_INFRA_BOOTSTRAP=0
ARTIFACT_RUNTIME_AUTO_BOOTSTRAP=0
LOCAL_CRAWL4AI_AUTO_BOOTSTRAP=0
LOCAL_PGVECTOR_AUTO_BOOTSTRAP=0
APPS_PUBLISH_JOB_EAGER=0
APPS_PUBLISH_MOCK_MODE=0
ARTIFACT_RUN_TASK_EAGER=0
APPS_BUILDER_BUILD_AUTOMATION_ENABLED=1

# Published apps / domains
APPS_BASE_DOMAIN=apps.example.com
APPS_URL_SCHEME=https

# Cloudflare R2 bundle storage
APPS_BUNDLE_BUCKET=talmudpedia-prod-bundles
APPS_BUNDLE_REGION=auto
APPS_BUNDLE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
APPS_BUNDLE_ACCESS_KEY=replace-with-r2-access-key
APPS_BUNDLE_SECRET_KEY=replace-with-r2-secret-key

# Optional: keep artifact bundles separate; otherwise omit and reuse APPS_BUNDLE_*
# ARTIFACT_BUNDLE_BUCKET=
# ARTIFACT_BUNDLE_REGION=
# ARTIFACT_BUNDLE_ENDPOINT=
# ARTIFACT_BUNDLE_ACCESS_KEY=
# ARTIFACT_BUNDLE_SECRET_KEY=

# Crawl4AI
CRAWL4AI_BASE_URL=https://crawl4ai-production.up.railway.app
CRAWL4AI_BEARER_TOKEN=

# Sprite runtime
APPS_SANDBOX_BACKEND=sprite
APPS_SPRITE_API_BASE_URL=https://api.sprites.dev
APPS_SPRITE_API_TOKEN=replace-with-sprite-token
SPRITES_TOKEN=replace-with-sprite-token

# Cloudflare artifact runtime
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_WORKERS_COMPATIBILITY_DATE=2026-03-11

# Provider/model credentials: set only the providers you actually use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PINECONE_API_KEY=
XAI_API_KEY=

# Optional external pgvector-capable Postgres if Railway Postgres does not support vector
# PGVECTOR_CONNECTION_STRING=
