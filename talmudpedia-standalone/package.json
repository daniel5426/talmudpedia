{
  "name": "talmudpedia-standalone",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && tsc -p tsconfig.server.json && vite build",
    "start": "node server-dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "provision:prico-demo": "tsx server/provision-prico-demo.ts",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.server.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@remixicon/react": "^4.9.0",
    "@rive-app/react-webgl2": "^4.27.1",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.1.0",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.1.17",
    "@agents24/embed-sdk": "1.0.0",
    "@tanstack/react-query": "^5.90.21",
    "@xyflow/react": "^12.10.1",
    "ai": "^6.0.116",
    "ansi-to-react": "^6.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "embla-carousel-react": "^8.6.0",
    "express": "^5.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "media-chrome": "^4.18.0",
    "motion": "^12.36.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-jsx-parser": "^2.4.1",
    "react-resizable-panels": "^4.7.3",
    "react-router-dom": "^7.13.1",
    "recharts": "2.15.4",
    "shadcn": "^4.0.8",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.17",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
